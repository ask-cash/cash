# Supabase — copy to .env and fill in from your project's Settings → API.
# These are exposed to the browser (Vite inlines VITE_* at build time); only use
# the public "anon" key here, never the service_role key.
VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
