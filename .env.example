# ============================================================
# 🤖 PERSONAL AI ASSISTANT — CONFIGURATION
# ============================================================
# Fill this out ONCE. The bot remembers everything from here.
# Copy this file to .env and fill in your values.
# ============================================================

# --- Bot & API Keys ---
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
ANTHROPIC_API_KEY=your_claude_api_key
YOUR_TELEGRAM_USER_ID=0

# --- Discord ---
# Bot token from https://discord.com/developers/applications
# Enable BOTH "Message Content Intent" and "Server Members Intent" on the Bot page.
DISCORD_BOT_TOKEN=
# The bot account's Discord user id (right-click bot → Copy User ID with dev mode on)
DISCORD_CASH_USER_ID=
# Your Discord user id
DISCORD_SUHAIL_USER_ID=
# Comma-separated guild ids Cash is allowed to operate in. Leave empty for dev.
DISCORD_ALLOWED_GUILD_IDS=
# Deferred reply window (minutes) — Cash waits this long before proxy-replying
DISCORD_PROXY_DELAY_MIN=30
DISCORD_PROXY_DELAY_MAX=40
# Master switch for actually sending proxy replies. Default false = dry-run:
# Cash composes the reply and writes it to user_data/discord_proxy_log.jsonl
# without posting. Flip to true once you've reviewed a few dry-runs.
DISCORD_PROXY_ENABLED=false
# How many channel messages before the mention to feed the composer for context.
DISCORD_PROXY_HISTORY_LIMIT=10

# --- Google Calendar ---
GOOGLE_CREDENTIALS_PATH=credentials.json
GOOGLE_TOKEN_PATH=token.json

# --- OAuth callback (used by /connect_google) ---
# OAUTH_REDIRECT_URI must match an "Authorized redirect URI" on your
# Google OAuth client. Point it at your ngrok public URL + /oauth2callback.
# Example: https://abc123.ngrok.app/oauth2callback
OAUTH_REDIRECT_URI=
OAUTH_SERVER_PORT=8080

# --- Gmail ---
# Uses the same credentials.json as Google Calendar
# On first run, a browser window will open for Gmail OAuth consent
GMAIL_TOKEN_PATH=gmail_token.json
EMAIL_CHECK_INTERVAL_SECONDS=1800

# --- Outlook / Microsoft Calendar ---
# Create an app at https://portal.azure.com → App registrations
# Redirect URI: http://localhost:8400
# Permissions: Calendars.ReadWrite, User.Read
OUTLOOK_CLIENT_ID=
OUTLOOK_CLIENT_SECRET=
OUTLOOK_TENANT_ID=common
OUTLOOK_TOKEN_PATH=outlook_token.json

# --- Your Identity ---
USER_NAME=User
TIMEZONE=Asia/Kolkata

# --- Wake / Sleep ---
WAKE_TIME=06:30
SLEEP_TIME=23:00

# --- Gym ---
GYM_TIME=07:30
GYM_DURATION_MINUTES=60
GYM_COMMUTE_MINUTES=15
GYM_CLOSES_AT=22:00
GYM_DAYS=Mon,Tue,Wed,Thu,Fri,Sat
# Format: Day:Routine separated by |
GYM_ROUTINE=Mon:Chest + Triceps|Tue:Back + Biceps|Wed:Legs|Thu:Shoulders + Abs|Fri:Arms + Cardio|Sat:Full Body

# --- Diet ---
# Format: time,name,items separated by |
DIET_MEALS=07:00,Pre-workout,Banana + black coffee|09:00,Breakfast,Eggs oats fruits|12:30,Lunch,Rice chicken/paneer veggies|16:00,Snack,Protein shake + nuts|19:30,Dinner,Salad soup grilled protein
WATER_GOAL_LITERS=3.5
SUPPLEMENTS=Whey protein,Creatine,Multivitamin,Fish oil

# --- Trading ---
MARKET_OPEN=09:15
MARKET_CLOSE=15:30
PRE_MARKET_REVIEW=08:45
# Separate rules with |
TRADING_RULES=Max 2 trades per day|Stop loss is mandatory on every trade|No revenge trading — walk away after 2 consecutive losses|Risk max 1% of capital per trade|No trading in first 15 minutes|Book partial profits at 1:1 RR trail the rest|No overnight positions unless swing setup confirmed|Journal every trade — entry reason exit reason emotion

# --- Default Daily Tasks ---
# Format: time,category,task separated by |
DEFAULT_TASKS=06:35,wellness,Morning meditation 10 min|08:45,trading,Review trading watchlist|10:00,work,Check emails and reply|10:30,work,Deep work block|12:30,wellness,Lunch break step away from screen|15:45,trading,Trading journal entry|18:00,wellness,Evening walk 20 min|22:00,planning,Plan tomorrow
